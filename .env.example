# Copy this file to `.env` and fill in the values before running
# `docker compose up`. `.env` is git-ignored.

# --- LLM classification backend (Ollama-compatible API) ---
# Endpoint URL. Leave empty to disable classification (safe defaults are
# returned with confidence=0.0).
OLLAMA_URL=
# Model name to request from that endpoint.
OLLAMA_MODEL=mistral
# Optional bearer token sent as `Authorization: Bearer <token>`.
# Leave empty if the endpoint does not require auth.
OLLAMA_BEARER_TOKEN=

# --- VirusTotal ---
# API key. Leave empty to disable VirusTotal submissions / lookups.
VT_API_KEY=

# --- InstruMate API auth ---
# Set to a strong random string to require `X-API-Key: <value>` on every
# /api/* request. Leave empty to disable auth (local use only).
INSTRUMATE_API_KEY=
